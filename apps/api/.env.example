# ─────────────────────────────────────────────
# Artwra API — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env — it contains secrets.

# PostgreSQL connection string (Supabase session pooler recommended for IPv6 compat)
# Format: postgresql://<user>.<project-ref>:<password>@<host>:5432/postgres
DATABASE_URL=postgresql://postgres.<your-project-ref>:<your-password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Direct connection for Prisma migrations (can be the same as DATABASE_URL for pooler)
DIRECT_URL=postgresql://postgres.<your-project-ref>:<your-password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Supabase project URL (found in Supabase dashboard → Project Settings → API)
SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase service role key — KEEP SECRET, never expose to clients
# Found in Supabase dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Express server port
PORT=3000

# Node environment (development | production)
NODE_ENV=development
