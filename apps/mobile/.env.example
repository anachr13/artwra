# ─────────────────────────────────────────────
# Artwra Mobile — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env — it contains secrets.
# All EXPO_PUBLIC_ variables are bundled into the app at build time.

# Supabase project URL (found in Supabase dashboard → Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase anon/public key — safe to expose to clients
# Found in Supabase dashboard → Project Settings → API → anon public
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Base URL of the Artwra API server (no trailing slash, no /api/v1 suffix)
# Local development: http://localhost:3000
# Production: https://api.yourdomain.com
EXPO_PUBLIC_API_URL=http://localhost:3000
